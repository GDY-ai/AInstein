# AInstein Environment Variables
# Copy this file to /etc/ainstein.env (or .env in project root)
# and fill in your values.

# LLM API Key (DashScope / compatible provider)
DASHSCOPE_API_KEY=sk-your-api-key-here

# LLM API Base URL (default: DashScope Anthropic endpoint)
# DASHSCOPE_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/apps/anthropic

# Model selection (default: kimi-k2.6)
# RESEARCH_MODEL=kimi-k2.6
# SCIENTIST_MODEL=kimi-k2.6
# DIRECTOR_MODEL=kimi-k2.6

# Database path (default: ./data/ainstein.db)
# AINSTEIN_DB=/opt/ainstein/data/ainstein.db
